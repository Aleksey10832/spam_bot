generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
model SpamBot {
  id            String    @default(uuid()) @id
  apiId         String    @unique
  apiHash       String
  phoneNumber   String
  password      String
  session       String
  isAuth        Boolean
  banStatus     Boolean
  sleepOk       Boolean
  initDate      DateTime
}
model Admin {
  id            String    @default(uuid()) @id
  telegramId    String    @unique
}
model User {
  id            String    @default(uuid()) @id
  lastMessage   String
  telegramId    String
  isOk          Boolean?
}